<?xml version = "1.0" encoding = "ISO-8859-1"?>

<!DOCTYPE controladores SYSTEM "dtds/controladores.dtd">

<controladores>

    <controlador nombre="Autenticador">
        <hereda-de controlador="Typical"/>
        <accion nombre="ingresar"
                clase="com.condominiospms.CondominiosPMS.acciones.AutenticadorAction"
                icono="login"/>
    </controlador>

    <controlador nombre="Copropietario">
        <hereda-de controlador="Typical"/>
    </controlador>

    <controlador nombre="Incidencia">
        <hereda-de controlador="Typical"/>
        <accion nombre="pasarAEnProceso"
                clase="com.condominiospms.CondominiosPMS.acciones.PasarAEnProcesoAction"
                icono="play-circle"/>
        <accion nombre="resolver"
                clase="com.condominiospms.CondominiosPMS.acciones.ResolverIncidenciaAction"
                icono="check-circle"/>
        <accion nombre="cancelar"
                clase="com.condominiospms.CondominiosPMS.acciones.CancelarIncidenciaAction"
                icono="close-circle"/>
    </controlador>

</controladores>